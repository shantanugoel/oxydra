# Lightweight Dockerfiles that package pre-built guest binaries.
# Used by scripts/build-guest-images.sh after local cross-compilation.
#
# Build each target separately:
#   docker build --build-arg BINARY=target/<triple>/release/oxydra-vm \
#                --target oxydra-vm -t oxydra-vm:latest \
#                -f docker/Dockerfile.prebuilt .
#
#   docker build --build-arg BINARY=target/<triple>/release/shell-daemon \
#                --target shell-vm -t shell-vm:latest \
#                -f docker/Dockerfile.prebuilt .

# --- oxydra-vm image ---
FROM alpine:3 AS oxydra-vm

ARG BINARY
RUN apk add --no-cache ca-certificates tzdata \
    && addgroup -S oxydra \
    && adduser -S -D -H -G oxydra oxydra
ENV HOME=/tmp/oxydra-home \
    XDG_CONFIG_HOME=/tmp/oxydra-home/.config \
    XDG_CACHE_HOME=/tmp/oxydra-home/.cache \
    XDG_STATE_HOME=/tmp/oxydra-home/.local/state \
    TZ=UTC
COPY ${BINARY} /usr/local/bin/oxydra-vm
RUN chmod +x /usr/local/bin/oxydra-vm
USER oxydra:oxydra
ENTRYPOINT ["/usr/local/bin/oxydra-vm"]

# --- shell-vm (shell-daemon sidecar) image ---
FROM alpine:3 AS shell-vm

ARG BINARY
ARG PINCHTAB_VERSION=0.7.6

RUN apk add --no-cache \
    # essentials
    ca-certificates \
    curl \
    # shell & scripting
    bash \
    jq \
    python3 \
    py3-pip \
    py3-setuptools \
    # file operations
    git \
    unzip \
    tar \
    file \
    ripgrep \
    fd \
    # text processing — GNU tools for LLM agent compatibility (replace BusyBox applets)
    grep \
    gawk \
    sed \
    # network tools
    bind-tools \
    netcat-openbsd \
    socat \
    # process tools
    procps \
    lsof \
    # build basics (agents often need to compile/run things)
    make \
    gcc \
    musl-dev \
    # Browser
    nss \
    tzdata \
    ttf-freefont \
    chromium \
    && addgroup -S oxydra \
    && adduser -S -D -H -G oxydra oxydra

# Download Pinchtab binary for the target architecture.
RUN ARCH=$(uname -m) && \
    case "$ARCH" in \
      x86_64)  ARCH="amd64" ;; \
      aarch64) ARCH="arm64" ;; \
      *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac && \
    curl -fSL "https://github.com/pinchtab/pinchtab/releases/download/v${PINCHTAB_VERSION}/pinchtab-linux-${ARCH}" \
      -o /usr/local/bin/pinchtab && \
    chmod +x /usr/local/bin/pinchtab

COPY ${BINARY} /usr/local/bin/shell-daemon
RUN chmod +x /usr/local/bin/shell-daemon
COPY docker/chromium-wrapper.sh /usr/local/bin/chromium-wrapper
RUN chmod +x /usr/local/bin/chromium-wrapper
COPY docker/shell-vm-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
ENV HOME=/tmp/oxydra-home \
    XDG_CONFIG_HOME=/tmp/oxydra-home/.config \
    XDG_CACHE_HOME=/tmp/oxydra-home/.cache \
    XDG_STATE_HOME=/tmp/oxydra-home/.local/state \
    TZ=UTC
USER oxydra:oxydra
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
